classDiagram
    %% Relationships & Connectors
    User <|-- Customer : Inheritance
    User <|-- Admin : Inheritance

    Customer "1" *-- "1" Cart : personalCart
    Cart "1" *-- "*" CartItem : items
    CartItem "*" --> "1" Product : product

    Core "1" o-- "*" User : usersDatabase
    Core "1" o-- "*" Product : inventory
    Core "1" o-- "*" Product : hotProducts
    Core "1" --> "1" Cart : guestCart

    GUI_MainFrame "1" *-- "1" HomeView
    GUI_MainFrame "1" *-- "1" CartView
    GUI_MainFrame "1" *-- "1" AdminView
    GUI_MainFrame "1" *-- "1" LoginView
    GUI_MainFrame "1" *-- "1" CustomerView

    HomeView --> Core
    CartView --> Core
    AdminView --> Core
    LoginView --> Core
    CustomerView --> Core

    HomeView --> GUI_MainFrame
    CartView --> GUI_MainFrame
    AdminView --> GUI_MainFrame
    LoginView --> GUI_MainFrame
    CustomerView --> GUI_MainFrame

    Main --> GUI_MainFrame

    %% Base User Class
    class User {
        <<Abstract>>
        -String username
        -String password
        +User(String username, String password)
        +verifyPassword(String password) boolean
    }

    %% Child Classes
    class Customer {
        -Cart personalCart
        +Customer(String username, String password)
        +checkout() boolean
    }

    class Admin {
        +Admin(String username, String password)
        +updateStock(Product p, int newStock) void
        +updatePrice(Product p, double newPrice) void
        +addNewProduct(Product p) void
    }

    %% Product & Cart Classes
    class Product {
        -String id
        -String name
        -double price
        -int stockQuantity
        +Product(String id, String name, double price, int stockQuantity)
        +reduceStock(int amount) boolean
    }

    class Cart {
        -List~CartItem~ items
        +Cart()
        +addItem(Product product, int quantity) void
        +removeItem(Product product) void
        +calculateTotal() double
        +clearCart() void
    }

    class CartItem {
        -Product product
        -int quantity
        +CartItem(Product product, int quantity)
        +increaseQuantity(int amount) void
    }

    %% The Main Controller (Singleton)
    class Core {
        -Core instance$
        -List~User~ usersDatabase
        -List~Product~ inventory
        -User loggedInUser
        -Cart guestCart
        -List~Product~ hotProducts
        +authenticate(String username, String password) User
        +processCheckout() boolean
        +routeUserView() String
        +registerCustomer(String username, String password) boolean
    }

    %% UI Representation
    class GUI_MainFrame {
        -CardLayout layout
        -Core core
        -JPanel mainPanel
        -HomeView homePanel
        -CartView cartPanel
        -AdminView adminPanel
        -LoginView loginPanel
        -CustomerView customerPanel
        -JButton cartBtn
        +GUI_MainFrame()
        +refreshCart() void
        +showHome() void
        +showCart() void
        +showAdmin() void
        +showLogin() void
        +showCustomer() void
        +updateCartButton(JButton button) void
    }

    class HomeView {
        -JPanel homePanel
        -JPanel hotProductsPanel
        -Core core
        -GUI_MainFrame mainFrame
        +HomeView(GUI_MainFrame mainFrame)
        +refreshHome() void
    }

    class CartView {
        -JPanel cartPanel
        -Core core
        -JPanel itemPanel
        -JLabel totalLabel
        -GUI_MainFrame mainFrame
        +CartView(GUI_MainFrame mainFrame)
        +refreshCart() void
        -displayCartItems(Cart targetCart) void
    }

    class AdminView {
        -JPanel adminPanel
        -Core core
        -JTextField idField
        -JTextField nameField
        -JTextField priceField
        -JTextField stockField
        -GUI_MainFrame mainFrame
        +AdminView(GUI_MainFrame mainFrame)
        -processAddProduct() void
    }

    class LoginView {
        -JPanel loginPanel
        -JTextField usernameField
        -JPasswordField passwordField
        -JButton loginBtn
        -JButton regBtn
        -GUI_MainFrame mainFrame
        +LoginView(GUI_MainFrame mainFrame)
    }

    class CustomerView {
        -JPanel customerPanel
        -Core core  
        -GUI_MainFrame mainFrame
        -JPanel historyPanel
        +CustomerView(GUI_MainFrame mainFrame)
    }

    class Main {
        +main(String[] args) void$
    }

